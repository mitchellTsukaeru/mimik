{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "noExplicitAny": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/entrypoints*", "tests/**/*", "wxt.config.ts", ".wxt/wxt.d.ts"]
}
